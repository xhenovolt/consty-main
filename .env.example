# Core app
# NODE_ENV is set automatically by Next.js (development for `next dev`,
# production for `next build`/`next start`). Do not hardcode it here.
API_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
LOG_LEVEL="info"

# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# Session / verification secrets
VERIFICATION_SECRET="replace-with-a-secure-random-string"
ENCRYPTION_KEY="replace-with-64-char-hex-key"
CREDENTIALS_ENCRYPTION_KEY="replace-with-secure-key"
BACKUP_ENCRYPTION_KEY="replace-with-secure-key"

# WebAuthn / passkeys
WEBAUTHN_RP_ID="localhost"
WEBAUTHN_ORIGIN="http://localhost:3000"
WEBAUTHN_RP_NAME="Consty"

# Optional media storage
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="your-upload-preset"

# Optional external integrations
DRAIS_API_BASE_URL="https://example.com/api"
DRAIS_API_KEY="your-drais-api-key"
DRAIS_API_SECRET="your-drais-api-secret"
DRAIS_PLATFORM_BASE_URL="https://example.com/api/platform/v1"
DRAIS_PLATFORM_TOKEN="your-platform-token"
DRAIS_WEBHOOK_SECRET="your-webhook-secret"
